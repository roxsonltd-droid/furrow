{
	"buildCommand": "echo static",
	"outputDirectory": ".",
	"framework": null,
	"rewrites": [
		{ "source": "/agridirect", "destination": "/agridirect/index.html" },
		{ "source": "/register", "destination": "/register.html" },
		{ "source": "/archive", "destination": "/archive.html" },
		{ "source": "/api/(.*)", "destination": "/api/$1" },
		{ "source": "/ukraine-harvest-war", "destination": "/ukraine-harvest-war.html" },
		{ "source": "/egypt-fields-desert-oasis-2026", "destination": "/egypt-fields-desert-oasis-2026.html" },
		{ "source": "/egypt-fields-desert-oasis-2026-ru", "destination": "/egypt-fields-desert-oasis-2026-ru.html" },
		{ "source": "/egypt-agriculture-analysis-en", "destination": "/egypt-agriculture-analysis-en.html" },
		{ "source": "/egypt-agriculture-analysis-ru", "destination": "/egypt-agriculture-analysis-ru.html" },
		{ "source": "/france-agriculture-analysis-en", "destination": "/france-agriculture-analysis-en.html" },
		{ "source": "/france-agriculture-analysis-ru", "destination": "/france-agriculture-analysis-ru.html" },
		{ "source": "/global-corn-producers-analysis-en", "destination": "/global-corn-producers-analysis-en.html" },
		{ "source": "/global-corn-producers-analysis-ru", "destination": "/global-corn-producers-analysis-ru.html" },
		{ "source": "/us-canada-wheat-trade-war-en", "destination": "/us-canada-wheat-trade-war-en.html" },
		{ "source": "/us-canada-wheat-trade-war-ru", "destination": "/us-canada-wheat-trade-war-ru.html" },
		{ "source": "/sponsor", "destination": "/sponsor.html" },
		{ "source": "/tomato-harvest-2026", "destination": "/tomato-harvest-2026.html" },
		{
			"source": "/coffee-under-pressure-global-industry",
			"destination": "/coffee-under-pressure-global-industry.html"
		}
	],
	"functions": {
		"api/**/*.ts": {
			"maxDuration": 60
		}
	}
}
